{
  "name": "vue-ts",
  "type": "module",
  "version": "0.3.1-beta.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "commit": "git add . && eslint . --fix && git add . && git commit",
    "release": "changelogen --release",
    "release:patch": "changelogen --release --patch",
    "release:minor": "changelogen --release --minor",
    "release:major": "changelogen --release --major",
    "release:alpha": "changelogen --release --prerelease alpha",
    "release:beta": "changelogen --release --prerelease beta",
    "release:rc": "changelogen --release --prerelease rc",
    "release:canary": "changelogen --release --prerelease canary --no-commit --no-tag",
    "prepare": "husky"
  },
  "dependencies": {
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "changelogen": "^0.6.2",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "~5.9.3",
    "unocss": "66.6.6",
    "vite": "^8.0.0",
    "vue-tsc": "^3.2.5"
  },
  "lint-staged": {
    "*.{js,ts,vue,json,css,scss,md,less}": [
      "eslint . --fix"
    ]
  }
}
